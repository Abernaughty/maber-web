{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "SCRYDEX_API_KEY",
        "SCRYDEX_TEAM_ID",
        "SCRYDEX_API_BASE_URL",
        "COSMOS_DB_CONNECTION_STRING",
        "COSMOS_DB_DATABASE_NAME",
        "COSMOS_DB_CARDS_CONTAINER_NAME",
        "COSMOS_DB_SETS_CONTAINER_NAME",
        "CACHE_TTL_SETS",
        "CACHE_TTL_CARDS"
      ],
      "outputs": [".svelte-kit/**", "build/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
