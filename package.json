{
  "name": "maber-web",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,svelte,js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,svelte,js,json,md,css}\"",
    "check": "turbo run check",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "prettier-plugin-svelte": "^3.3.0",
    "turbo": "^2.5.0"
  }
}
